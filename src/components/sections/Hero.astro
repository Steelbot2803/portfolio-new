---
import { ArrowRight, Github, Linkedin, MapPin } from "@lucide/astro";

interface Props {
  profile: {
    name: string;
    role: string;
    location: string;
    tagline: string;
    shortBio: string;
    linkedin: string;
    github: string;
  };
  stats: { label: string; value: string }[];
}

const { profile, stats } = Astro.props;
---

<section id="top" class="mx-auto w-full max-w-6xl px-5 pb-8 pt-16 sm:pt-20">
  <p
    class="inline-flex items-center gap-2 rounded-full border border-brand-panel-border/80 bg-brand-panel/75 px-3 py-1 text-sm font-medium text-brand-muted shadow-sm"
  >
    <MapPin size={20} />
    {profile.location}
  </p>
  <h1
    class="mt-1 text-4xl font-bold tracking-tight text-brand-text sm:text-5xl"
  >
    {profile.name}
  </h1>
  <h2 class="mt-2 text-xl font-medium text-brand-muted">{profile.role}</h2>
  <p class="mt-5 max-w-3xl text-base leading-7 text-brand-text">
    {profile.tagline}
  </p>
  <p class="mt-3 max-w-3xl text-base leading-7 text-brand-muted">
    {profile.shortBio}
  </p>
  <div class="mt-6 flex flex-wrap gap-3">
    <a
      class="inline-flex items-center gap-2 rounded-full border border-brand-panel-border bg-brand-panel px-4 py-2 text-sm font-medium text-brand-text shadow-sm hover:border-brand-link/35 hover:bg-brand-bg"
      href={profile.linkedin}
      target="_blank"
      rel="noopener noreferrer"
    >
      <Linkedin size={20} />
      LinkedIn
    </a>
    <a
      class="inline-flex items-center gap-2 rounded-full border border-brand-panel-border bg-brand-panel px-4 py-2 text-sm font-medium text-brand-text shadow-sm hover:border-brand-link/35 hover:bg-brand-bg"
      href={profile.github}
      target="_blank"
      rel="noopener noreferrer"
    >
      <Github size={20} />
      GitHub
    </a>
    <a
      class="inline-flex items-center gap-2 rounded-full border border-brand-accent bg-brand-accent px-4 py-2 text-sm font-medium text-brand-accent-contrast shadow-sm hover:brightness-110"
      href="#contact"
    >
      <ArrowRight size={20} />
      Get Back to Me
    </a>
  </div>
  <div class="mt-7 grid gap-3 sm:grid-cols-3">
    {
      stats.map((s) => (
        <article class="rounded-xl border border-brand-panel-border bg-brand-panel p-4 shadow-sm">
          <strong class="block text-2xl font-semibold text-brand-text">
            {s.value}
          </strong>
          <span class="mt-1 block text-sm text-brand-muted">{s.label}</span>
        </article>
      ))
    }
  </div>
</section>
