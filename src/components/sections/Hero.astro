---
interface Props {
  profile: {
    name: string;
    role: string;
    location: string;
    tagline: string;
    shortBio: string;
    linkedin: string;
    github: string;
  };
  stats: { label: string; value: string }[];
}

const { profile, stats } = Astro.props;
---

<section id="top" class="mx-auto w-full max-w-6xl px-5 pb-8 pt-16 sm:pt-20">
  <p class="text-sm text-brand-muted">{profile.location}</p>
  <h1 class="mt-1 text-4xl font-bold tracking-tight text-brand-text sm:text-5xl">{profile.name}</h1>
  <h2 class="mt-2 text-xl text-brand-muted">{profile.role}</h2>
  <p class="mt-5 max-w-3xl text-base leading-7 text-brand-text/90">{profile.tagline}</p>
  <p class="mt-3 max-w-3xl text-base leading-7 text-brand-muted">{profile.shortBio}</p>
  <div class="mt-6 flex flex-wrap gap-3">
    <a class="rounded-full border border-brand-panel-border px-4 py-2 text-sm text-brand-text hover:bg-brand-bg/60" href={profile.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
    <a class="rounded-full border border-brand-panel-border px-4 py-2 text-sm text-brand-text hover:bg-brand-bg/60" href={profile.github} target="_blank" rel="noopener noreferrer">GitHub</a>
    <a class="rounded-full border border-brand-accent/60 px-4 py-2 text-sm text-brand-accent-contrast hover:bg-brand-accent/15" href="#contact">Get Back to Me</a>
  </div>
  <div class="mt-7 grid gap-3 sm:grid-cols-3">
    {
      stats.map((s) => (
        <article class="rounded-xl border border-brand-panel-border bg-brand-panel p-4">
          <strong class="block text-2xl font-semibold text-brand-text">{s.value}</strong>
          <span class="mt-1 block text-sm text-brand-muted">{s.label}</span>
        </article>
      ))
    }
  </div>
</section>
