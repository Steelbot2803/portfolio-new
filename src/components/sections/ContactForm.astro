---
import { Clock3, Mail, MessageSquare, Phone, Send, User } from "lucide";
import LucideIcon from "../ui/LucideIcon.astro";

interface Props {
  heading: string;
  description: string;
  privacyNote: string;
}

const { heading, description, privacyNote } = Astro.props;
---

<section id="contact" class="mx-auto w-full max-w-6xl px-5 py-8 pb-16">
  <h3 class="text-2xl font-semibold tracking-tight text-brand-text">
    {heading}
  </h3>
  <p class="mt-3 max-w-3xl leading-7 text-brand-muted">{description}</p>
  <form
    name="contactForm"
    method="POST"
    data-netlify="true"
    data-netlify-honeypot="company"
    id="contactForm"
    class="mt-6 grid max-w-2xl gap-3 rounded-2xl border border-brand-panel-border bg-brand-panel/90 p-5 shadow-sm"
  >
    <input type="hidden" name="form-name" value="contactForm" />
    <input
      name="company"
      autocomplete="off"
      tabindex="-1"
      aria-hidden="true"
      class="hidden"
    />

    <label class="grid gap-1 text-sm text-brand-text/90">
      <span class="inline-flex items-center gap-2">
        <LucideIcon icon={User} />
        Full Name*
      </span>
      <input
        required
        name="name"
        class="rounded-lg border border-brand-panel-border bg-brand-panel px-3 py-2 text-brand-text placeholder:text-brand-muted/80 focus:border-brand-link"
      />
    </label>

    <label class="grid gap-1 text-sm text-brand-text/90">
      <span class="inline-flex items-center gap-2">
        <LucideIcon icon={Mail} />
        Email*
      </span>
      <input
        required
        type="email"
        name="email"
        class="rounded-lg border border-brand-panel-border bg-brand-panel px-3 py-2 text-brand-text placeholder:text-brand-muted/80 focus:border-brand-link"
      />
    </label>

    <label class="grid gap-1 text-sm text-brand-text/90">
      <span class="inline-flex items-center gap-2">
        <LucideIcon icon={Phone} />
        Phone
      </span>
      <input
        name="phone"
        type="tel"
        placeholder="Please include country code"
        class="rounded-lg border border-brand-panel-border bg-brand-panel px-3 py-2 text-brand-text placeholder:text-brand-muted/80 focus:border-brand-link"
      />
    </label>

    <label class="grid gap-1 text-sm text-brand-text/90">
      <span class="inline-flex items-center gap-2">
        <LucideIcon icon={Clock3} />
        Preferred callback window
      </span>
      <input
        name="callbackWindow"
        placeholder="e.g. Weekdays 6-8 PM"
        class="rounded-lg border border-brand-panel-border bg-brand-panel px-3 py-2 text-brand-text placeholder:text-brand-muted/80 focus:border-brand-link"
      />
    </label>

    <label class="grid gap-1 text-sm text-brand-text/90">
      <span class="inline-flex items-center gap-2">
        <LucideIcon icon={MessageSquare} />
        Message*
      </span>
      <textarea
        required
        name="message"
        rows="5"
        class="rounded-lg border border-brand-panel-border bg-brand-panel px-3 py-2 text-brand-text placeholder:text-brand-muted/80 focus:border-brand-link"
      ></textarea>
    </label>

    <button
      type="submit"
      class="mt-2 inline-flex w-fit items-center gap-2 rounded-lg bg-brand-accent px-4 py-2 text-sm font-medium text-brand-accent-contrast shadow-sm hover:brightness-110"
    >
      <LucideIcon icon={Send} />
      Send Details
    </button>
    <p
      id="contactStatus"
      role="status"
      class="text-sm font-medium text-brand-muted"
    >
    </p>
  </form>
  <p class="mt-3 text-sm text-brand-muted">{privacyNote}</p>
</section>

<script>
  const form = document.querySelector<HTMLFormElement>("#contactForm");
  const status = document.querySelector<HTMLParagraphElement>("#contactStatus");
  const encodeForm = (formData: FormData) =>
    new URLSearchParams(
      Array.from(formData.entries()).map(([key, value]) => [
        key,
        String(value),
      ]),
    ).toString();

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const formData = new FormData(form);
    const payload = Object.fromEntries(formData.entries());

    if (!payload.name || !payload.email || !payload.message) {
      if (status) status.textContent = "Please fill in all required fields.";
      return;
    }

    try {
      if (status) status.textContent = "Sending...";
      const response = await fetch("/", {
        method: "POST",
        headers: { "Content-Type": "application/x-www-form-urlencoded" },
        body: encodeForm(formData),
      });

      if (!response.ok) {
        throw new Error("Submission failed");
      }

      form.reset();
      if (status) status.textContent = "Thanks! I will get back to you soon.";
    } catch {
      if (status)
        status.textContent =
          "Could not submit right now. Please email me directly.";
    }
  });
</script>
